# Public webhook URLs — safe to expose, used by the frontend
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-host/webhook/dizilo-contact
NEXT_PUBLIC_N8N_BOOKING_WEBHOOK_URL=https://your-n8n-host/webhook/dizilo-book

# Private — n8n admin API (never commit these)
N8N_API_KEY=your_n8n_api_key_here
N8N_HOST=your_n8n_hostname_here
GMAIL_CRED_ID=your_gmail_credential_id
GCAL_CRED_ID=your_gcal_credential_id
SHEETS_CRED_ID=your_google_sheets_credential_id
GOOGLE_SHEET_ID=your_google_sheet_id
OWNER_EMAILS=owner1@email.com,owner2@email.com
